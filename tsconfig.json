{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/game/*": ["./game/*"]
    }
  },
  "include": ["game/**/*.ts", "harness/src/**/*.ts", "harness/src/**/*.tsx"],
  "exclude": ["node_modules", "server/node_modules", "harness/node_modules", "harness/dist"]
}
