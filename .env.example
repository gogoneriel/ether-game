# Shared HMAC secret for WS join tokens (local / CI only — never commit real secrets)
GAME_WS_SECRET=dev-test-secret

# Caddy site address (production hostname or localhost for local TLS testing)
GAME_HOST=localhost

# Optional: override WS URL returned by the harness token stub
# GAME_WS_URL=ws://127.0.0.1:8080/ws
